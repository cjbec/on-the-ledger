{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    { "path": "/api/cron/rss",                  "schedule": "0 7 * * *"   },
    { "path": "/api/cron/edgar?company=bill",    "schedule": "0 8 * * *"   },
    { "path": "/api/cron/edgar?company=intuit",  "schedule": "5 8 * * *"   },
    { "path": "/api/cron/rollup",               "schedule": "0 9 * * *"   }
  ],
  "functions": {
    "api/**/*.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/index.html" }
  ]
}
